{
  "run": {
    "mode": "simulate",
    "duration_seconds": 21600,
    "time_step_seconds": 60
  },
  "greenhouse": {
    "length_m": 12.0,
    "width_m": 6.0,
    "height_m": 3.0
  },
  "grid": {
    "nx": 12,
    "ny": 6,
    "nz": 4
  },
  "initial_state": {
    "temperature_c": 18.0,
    "humidity_percent": 60.0
  },
  "weather": {
    "outside_temperature_c": 5.0,
    "outside_humidity_percent": 75.0,
    "solar_radiation_w_m2": 350.0,
    "weather_file": "data/weather_sample.csv"
  },
  "material": {
    "name": "polycarbonate",
    "heat_loss_coefficient": 0.35,
    "solar_transmission": 0.75
  },
  "vents": [
    {
      "name": "left_roof_vent",
      "position": [2.0, 0.5, 2.8],
      "opening": 0.3,
      "influence_radius_m": 2.0
    },
    {
      "name": "right_roof_vent",
      "position": [10.0, 5.5, 2.8],
      "opening": 0.3,
      "influence_radius_m": 2.0
    }
  ],
  "heaters": [
    {
      "name": "heater_1",
      "position": [3.0, 3.0, 0.2],
      "power_w": 1200.0,
      "influence_radius_m": 2.5
    },
    {
      "name": "heater_2",
      "position": [9.0, 3.0, 0.2],
      "power_w": 1200.0,
      "influence_radius_m": 2.5
    }
  ],
  "humidity": {
    "enabled": true,
    "humidifier_mode": "medium"
  },
  "humidifiers": [
    {
      "name": "humidifier_1",
      "position": [6.0, 3.0, 0.5],
      "mode": "medium",
      "influence_radius_m": 2.0
    }
  ],
  "plants": [
    {
      "name": "plant_1",
      "position": [3.0, 2.0, 0.5],
      "target_temperature_c": 22.0
    },
    {
      "name": "plant_2",
      "position": [6.0, 3.0, 0.5],
      "target_temperature_c": 22.0
    },
    {
      "name": "plant_3",
      "position": [9.0, 4.0, 0.5],
      "target_temperature_c": 22.0
    }
  ],
  "optimizer": {
    "enabled": false,
    "candidate_step_m": 1.0,
    "max_candidates": 30,
    "max_layouts": 500,
    "energy_weight": 0.05
  },
  "output": {
    "directory": "outputs",
    "write_csv": true,
    "write_json": true,
    "write_report": true
  }
